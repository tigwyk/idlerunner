# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Supabase project values.
# Create a free project at https://supabase.com

# Client-side (Vite exposes VITE_* vars to the browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side (never expose the service role key to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Fastify server ───────────────────────────────────────────────────────────
# URL the Vite client uses to reach the Fastify backend
VITE_MULTIPLAYER_API_URL=http://localhost:3001

# ─── Production only ─────────────────────────────────────────────────────────
# Lock CORS to your client's public URL. If unset, the server allows any origin
# (acceptable for local dev, not for production).
# ALLOWED_ORIGIN=https://marathon-idle.pages.dev

# Optional: override the port/host the Fastify server binds to
# PORT=3001
# HOST=0.0.0.0

